# Generic agent Dockerfile.
# Build arg AGENT_PKG selects which example to build, e.g. ./examples/company-b-writer
ARG AGENT_PKG=./examples/company-b-writer

FROM golang:1.26-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod go mod download
COPY . .
ARG AGENT_PKG
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o bin/agent ${AGENT_PKG}

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /build/bin/agent ./agent
ENTRYPOINT ["./agent"]
